{
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ES2022",
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["shared/lib/**/*.js", "shared/components/**/*.jsx"]
}
