# Copy to .env.local (gitignored). Never commit real secrets.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_KEY=your_anon_key

# Optional product label
VITE_APP_TITLE=Campaign Console

# Must match `session_state.id` for the live row (default session-1)
# VITE_DEFAULT_SESSION_RUN_ID=session-1

# Seedless is default ON; set to 0 to force legacy green-hunger implicit slug
# VITE_SEEDLESS_PLATFORM=0
# VITE_DEMO_CAMPAIGN=1

# Local-only emergency gate (never set in production builds)
# VITE_DM_EMERGENCY_UNLOCK=
